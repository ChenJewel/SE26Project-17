{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": false,
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "lucide-react": ["src/components/LucideShim.tsx"]
    },
    "types": ["@tarojs/taro", "@tarojs/components"]
  },
  "include": ["src", "config", "babel.config.js"],
  "references": []
}
