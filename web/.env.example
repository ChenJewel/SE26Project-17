# Android App / Ubuntu backend runtime settings.
#
# Copy this file to `.env.local` for local development or `.env.production`
# for production builds. Do not commit real secrets.

# App WebView must not call localhost after packaging.
# Use your Ubuntu server IP/domain. Recommended with Nginx reverse proxy:
# VITE_API_BASE_URL=http://YOUR_UBUNTU_SERVER_IP/api
# Temporary direct-port debugging only if security group allows 3000:
# VITE_API_BASE_URL=http://YOUR_UBUNTU_SERVER_IP:3000
VITE_API_BASE_URL=http://127.0.0.1:3000

# Optional WebSocket endpoint for chat/realtime features.
# Recommended with Nginx reverse proxy:
# VITE_WS_URL=ws://YOUR_UBUNTU_SERVER_IP
# Temporary direct-port debugging:
# VITE_WS_URL=ws://YOUR_UBUNTU_SERVER_IP:3000
VITE_WS_URL=ws://127.0.0.1:3000

# Set to capacitor when building the Web assets that will be synced into Android.
VITE_APP_TARGET=web
