{
  "name": "ueat-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "embedding:check": "tsx src/tools/embeddingProviderCheck.ts",
    "embedding:backfill": "tsx src/tools/embeddingBackfill.ts",
    "embedding:quality": "tsx src/tools/embeddingQualityCheck.ts",
    "recommendation:backfill": "tsx src/tools/mealCardRecommendationBackfill.ts",
    "recommendation:feedback": "tsx src/tools/recommendationFeedbackSummary.ts",
    "ai-suggestions:quality": "tsx scripts/ai-suggestion-quality-check.ts",
    "semantic:baseline": "tsx scripts/semantic-baseline.ts",
    "semantic:candidates": "tsx scripts/semantic-candidates.ts",
    "s0:baseline": "tsx scripts/s0-baseline.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
