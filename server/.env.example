PORT=3000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,capacitor://localhost,http://localhost
DATABASE_URL=postgresql:///ueat?host=/var/run/postgresql
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen3:1.7b
AI_MODEL_TIMEOUT_MS=60000
AI_MODEL_KEEP_ALIVE=15m
AI_MODEL_NUM_PREDICT=220
AI_MODEL_NUM_CTX=2048
AI_PROMPT_MAX_EVIDENCE_SIGNALS=3
AI_PROMPT_MAX_MESSAGES=4
AI_EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=bge-m3
AI_EMBEDDING_VECTOR_DIMENSIONS=1024
AI_EMBEDDING_TIMEOUT_MS=15000
AI_EMBEDDING_BACKFILL_BATCH_SIZE=12
AI_PGVECTOR_ENABLED=true
AI_PRIVACY_HASH_SECRET=replace-with-random-hex-secret
